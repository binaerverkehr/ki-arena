# ============================================================
# KI Arena – Konfiguration
# ============================================================
# Kopiere diese Datei nach .env und trage deine API-Keys ein:
#   cp .env.example .env
#
# Du brauchst mindestens EINEN der folgenden Provider:
# - Anthropic (Claude-Modelle)
# - OpenAI (GPT-Modelle)
# - Ollama (lokale Modelle, kein Key nötig)

# ── LLM-Provider ────────────────────────────────────────────
# Anthropic: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Ollama: Lokal, kein Key nötig. Standard-URL anpassen falls nötig.
OLLAMA_BASE_URL=http://localhost:11434

# ── Server ──────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=true

# ── Ausgabe ─────────────────────────────────────────────────
# Ordner für generierte Debatten (Audio + JSON-Metadaten).
# Wird automatisch erstellt.
DEBATES_DIR=./debates
